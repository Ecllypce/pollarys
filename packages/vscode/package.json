{
  "name": "pollarys",
  "displayName": "Pollarys",
  "description": "AI coding assistant powered by OpenCode",
  "version": "1.11.3",
  "publisher": "fedaykindev",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/btriapitsyn/pollarys.git"
  },
  "qna": "https://discord.gg/ZYRSdnwwKA",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "ai",
    "claude",
    "gpt",
    "agent",
    "coding",
    "chatgpt",
    "groq",
    "assistant",
    "opencode",
    "pollarys"
  ],
  "icon": "assets/app-icon.png",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onCommand:pollarys.openSidebar",
    "onCommand:pollarys.attachExplorerToChat",
    "onView:pollarys.chatView"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pollarys",
          "title": "Pollarys",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "views": {
      "pollarys": [
        {
          "type": "webview",
          "id": "pollarys.chatView",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "pollarys.openSidebar",
        "category": "Pollarys",
        "title": "Open Sidebar",
        "icon": {
          "light": "assets/icon.svg",
          "dark": "assets/icon-titlebar.svg"
        }
      },
      {
        "command": "pollarys.focusChat",
        "category": "Pollarys",
        "title": "Focus Chat"
      },
      {
        "command": "pollarys.restartApi",
        "category": "Pollarys",
        "title": "Restart API Connection"
      },
      {
        "command": "pollarys.showOpenCodeStatus",
        "category": "Pollarys",
        "title": "Show OpenCode Status"
      },
      {
        "command": "pollarys.openAgentManager",
        "category": "Pollarys",
        "title": "Open Agent Manager",
        "icon": "$(circuit-board)"
      },
      {
        "command": "pollarys.openActiveSessionInEditor",
        "category": "Pollarys",
        "title": "Open Active Session in Editor",
        "icon": "$(link-external)"
      },
      {
        "command": "pollarys.openNewSessionInEditor",
        "category": "Pollarys",
        "title": "Open New Session in Editor",
        "icon": {
          "light": "assets/icon.svg",
          "dark": "assets/icon-titlebar.svg"
        }
      },
      {
        "command": "pollarys.openCurrentOrNewSessionInEditor",
        "category": "Pollarys",
        "title": "Open Session in Editor",
        "icon": "$(link-external)"
      },
      {
        "command": "pollarys.addToContext",
        "category": "Pollarys",
        "title": "Add to Context"
      },
      {
        "command": "pollarys.explain",
        "category": "Pollarys",
        "title": "Explain"
      },
      {
        "command": "pollarys.improveCode",
        "category": "Pollarys",
        "title": "Improve Code"
      },
      {
        "command": "pollarys.newSession",
        "category": "Pollarys",
        "title": "New Session",
        "icon": "$(add)"
      },
      {
        "command": "pollarys.showSettings",
        "category": "Pollarys",
        "title": "Settings",
        "icon": "$(settings-gear)"
      },
      {
        "command": "pollarys.attachExplorerToChat",
        "category": "Pollarys",
        "title": "Attach to Pollarys Chat"
      }
    ],
    "submenus": [
      {
        "id": "pollarys.submenu",
        "label": "Pollarys"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "pollarys.submenu",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "pollarys.attachExplorerToChat",
          "when": "resourceScheme == file && explorerResourceIsFolder == false",
          "group": "navigation@50"
        }
      ],
      "editor/title": [
        {
          "command": "pollarys.openNewSessionInEditor",
          "group": "navigation@1"
        }
      ],
      "view/title": [
        {
          "command": "pollarys.newSession",
          "when": "view == pollarys.chatView",
          "group": "navigation@1"
        },
        {
          "command": "pollarys.openCurrentOrNewSessionInEditor",
          "when": "view == pollarys.chatView",
          "group": "navigation@2"
        },
        {
          "command": "pollarys.openAgentManager",
          "when": "view == pollarys.chatView",
          "group": "navigation@3"
        },
        {
          "command": "pollarys.showSettings",
          "when": "view == pollarys.chatView",
          "group": "navigation@4"
        }
      ],
      "pollarys.submenu": [
        {
          "command": "pollarys.explain"
        },
        {
          "command": "pollarys.improveCode"
        },
        {
          "command": "pollarys.addToContext"
        }
      ]
    },
    "configuration": {
      "title": "Pollarys",
      "properties": {
        "pollarys.apiUrl": {
          "type": "string",
          "default": "",
          "description": "URL of an external OpenCode API server. Leave empty to auto-start a local instance."
        },
        "pollarys.opencodeBinary": {
          "type": "string",
          "default": "",
          "description": "Optional absolute path to the opencode CLI binary. Useful if PATH lookup fails. Requires window reload or API restart to apply."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "bun run build",
    "build": "bun run build:extension && bun run build:webview",
    "build:extension": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify --main-fields=module,main",
    "build:webview": "VITE_OPENCODE_URL=/api vite build",
    "dev": "concurrently -n \"ext,web\" -c \"cyan,magenta\" \"bun run watch:extension\" \"bun run dev:webview\"",
    "dev:webview": "vite --host localhost --port 5173 --strictPort",
    "watch:extension": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch --sourcemap --main-fields=module,main",
    "watch:webview": "vite build --watch",
    "type-check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.webview.json",
    "lint": "bunx eslint --ext .ts,.tsx src webview",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vscode/vsce": "^3.2.1",
    "concurrently": "^9.2.1",
    "esbuild": "^0.24.2",
    "typescript": "~5.8.3",
    "vite": "^7.1.2"
  },
  "dependencies": {
    "@pollarys/ui": "workspace:*",
    "@opencode-ai/sdk": "^1.15.5",
    "adm-zip": "^0.5.16",
    "jsonc-parser": "^3.3.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "yaml": "^2.8.1"
  }
}

